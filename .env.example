# ============================================================
# Cypress Environment Variables - Copy to .env and fill in
# ============================================================
# Active environment: dev | qa | staging | prod
CYPRESS_ENV=qa

# Override credentials (optional - env JSON files hold defaults)
CYPRESS_USERNAME=your-username@example.com
CYPRESS_PASSWORD=your-secure-password

# Cypress Cloud / Dashboard (optional - for parallel execution)
CYPRESS_RECORD_KEY=your-cypress-cloud-record-key

# Secrets that should NEVER be committed to source control
CYPRESS_API_SECRET_KEY=your-api-secret-key
